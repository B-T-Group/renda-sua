# Frontend Environment Variables

# Hasura GraphQL endpoint
REACT_APP_HASURA_URL=http://localhost:8080/v1/graphql

# Auth0 Configuration (update these with your actual values)
REACT_APP_AUTH0_DOMAIN=groupe-bt-client-dev.us.auth0.com
REACT_APP_AUTH0_CLIENT_ID=8O0pK4ySmqP3rBW53K15I3yFsgx5v7Mw
REACT_APP_AUTH0_AUDIENCE=https://groupe-bt-client-dev.us.auth0.com/api/v2/

# Backend API URL
REACT_APP_BACKEND_URL=http://localhost:3000

# Feature flags
REACT_APP_ENABLE_DEBUG_MODE=true
REACT_APP_ENABLE_ANALYTICS=false

# Internationalization
REACT_APP_DEFAULT_LOCALE=en
REACT_APP_SUPPORTED_LOCALES=en,fr

# Development settings
REACT_APP_ENABLE_HOT_RELOAD=true
REACT_APP_ENABLE_SOURCE_MAPS=true
